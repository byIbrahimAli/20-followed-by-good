# Copy to .env.local and fill in real values (gitignored).
# Production (full Quran): use production CLIENT_ID/SECRET; omit service URL overrides.
# Prelive (test): use prelive credentials + full prelive host block from .env.example.

PORT=3000
# Required locally. On Vercel optional for *.vercel.app — see docs/deploy-vercel.md
APP_BASE_URL=http://localhost:3000
CLIENT_ID=your_production_client_id
CLIENT_SECRET=your_production_client_secret
SESSION_SECRET=replace_with_a_long_random_secret
SCOPES=openid offline_access user note collection bookmark goal preference post comment
TRANSLATION_IDS=20
DEFAULT_READER_CHAPTER=1

# Optional: verify OAuth before npm run dev
# npm run smoke:oauth

# Optional local stack (api-js docker) — uncomment instead of QF production:
# OAUTH2_BASE_URL=http://localhost:5444
# TOKEN_HOST=http://localhost:5444
# AUTH_BASE_URL=http://localhost:3001
# CONTENT_BASE_URL=http://localhost:3020
# SEARCH_BASE_URL=http://localhost:3002
# QURAN_REFLECT_BASE_URL=http://localhost:9000
# GATEWAY_URL=http://localhost:5443

# Optional Redis
# REDIS_URL=redis://localhost:6379
