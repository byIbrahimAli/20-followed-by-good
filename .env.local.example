PORT=3000
APP_BASE_URL=http://localhost:3000
CLIENT_ID=local_confidential_client_id
CLIENT_SECRET=local_confidential_client_secret
SESSION_SECRET=local_dev_only_secret_change_me
SCOPES=openid offline_access user note collection bookmark goal preference post comment
TRANSLATION_IDS=131
DEFAULT_READER_CHAPTER=1

# Local stack endpoints
OAUTH2_BASE_URL=http://localhost:5444
TOKEN_HOST=http://localhost:5444
AUTH_BASE_URL=http://localhost:3001
CONTENT_BASE_URL=http://localhost:3020
SEARCH_BASE_URL=http://localhost:3002
QURAN_REFLECT_BASE_URL=http://localhost:9000
GATEWAY_URL=http://localhost:5443

# Optional local Redis
# REDIS_URL=redis://localhost:6379

# --- Quran Foundation pre-production (remote test stack) ---
# Copy this block into .env.local when using hackathon / prelive credentials.
# Never commit real CLIENT_ID or CLIENT_SECRET.
#
# CLIENT_ID=your_prelive_client_id
# CLIENT_SECRET=your_prelive_client_secret
# OAUTH2_BASE_URL=https://prelive-oauth2.quran.foundation
# TOKEN_HOST=https://prelive-oauth2.quran.foundation
# AUTH_BASE_URL=https://apis-prelive.quran.foundation
# CONTENT_BASE_URL=https://apis-prelive.quran.foundation
# SEARCH_BASE_URL=https://apis-prelive.quran.foundation
