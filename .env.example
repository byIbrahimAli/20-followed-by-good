# Required (all environments)
PORT=3000
APP_BASE_URL=http://localhost:3000
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
SESSION_SECRET=replace_with_a_long_random_secret

# Optional runtime behavior
SCOPES=openid offline_access user note collection bookmark goal preference post comment
TRANSLATION_IDS=20
DEFAULT_READER_CHAPTER=1
# DEFAULT_RECITER_ID=7
# DEFAULT_TAFSIR_ID=169

# Optional production session store
# REDIS_URL=redis://localhost:6379

# --- Production (live) — recommended for full Quran content ---
# Register your app at Quran Foundation, then set CLIENT_ID / CLIENT_SECRET in .env.local only.
# Omit the service URL overrides below to use SDK defaults:
#   oauth2: https://oauth2.quran.foundation
#   apis:   https://apis.quran.foundation
#
# OAuth: POST /oauth2/token with client_credentials + scope=content (see npm run smoke:oauth)
# Docs: https://api-docs.quran.foundation/docs/quickstart/
#
# CLIENT_ID=your_production_client_id
# CLIENT_SECRET=your_production_client_secret
#
# Optional explicit overrides (production only — do not mix with prelive):
# OAUTH2_BASE_URL=https://oauth2.quran.foundation
# TOKEN_HOST=https://oauth2.quran.foundation
# GATEWAY_URL=https://apis.quran.foundation
# CONTENT_BASE_URL=https://apis.quran.foundation

# --- Pre-production (test) — limited ayahs, full user/OAuth features ---
# Use a prelive CLIENT_ID/SECRET together with ALL prelive hosts below.
# Never mix prelive OAuth with production API hosts (or vice versa).
#
# CLIENT_ID=your_prelive_client_id
# CLIENT_SECRET=your_prelive_client_secret
# OAUTH2_BASE_URL=https://prelive-oauth2.quran.foundation
# TOKEN_HOST=https://prelive-oauth2.quran.foundation
# AUTH_BASE_URL=https://apis-prelive.quran.foundation
# CONTENT_BASE_URL=https://apis-prelive.quran.foundation
# SEARCH_BASE_URL=https://apis-prelive.quran.foundation
# QURAN_REFLECT_BASE_URL=https://apis-prelive.quran.foundation
# GATEWAY_URL=https://apis-prelive.quran.foundation
