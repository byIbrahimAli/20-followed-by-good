# Required
PORT=3000
APP_BASE_URL=http://localhost:3000
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
SESSION_SECRET=replace_with_a_long_random_secret

# Optional runtime behavior
SCOPES=openid offline_access user note collection bookmark goal preference post comment
TRANSLATION_IDS=131
DEFAULT_READER_CHAPTER=1

# Optional production session store
# REDIS_URL=redis://localhost:6379

# Optional service overrides (leave empty for built-in production defaults)
# OAUTH2_BASE_URL=https://oauth2.quran.foundation
# AUTH_BASE_URL=https://apis.quran.foundation
# CONTENT_BASE_URL=https://apis.quran.foundation
# SEARCH_BASE_URL=https://apis.quran.foundation
# QURAN_REFLECT_BASE_URL=https://apis.quran.foundation
# GATEWAY_URL=https://apis.quran.foundation
# TOKEN_HOST=https://oauth2.quran.foundation

# Pre-production (test) — register app at Quran Foundation, then set in .env.local only
# CLIENT_ID=your_prelive_client_id
# CLIENT_SECRET=your_prelive_client_secret
# OAUTH2_BASE_URL=https://prelive-oauth2.quran.foundation
# TOKEN_HOST=https://prelive-oauth2.quran.foundation
# AUTH_BASE_URL=https://apis-prelive.quran.foundation
# CONTENT_BASE_URL=https://apis-prelive.quran.foundation
# SEARCH_BASE_URL=https://apis-prelive.quran.foundation
# QURAN_REFLECT_BASE_URL=https://apis-prelive.quran.foundation
# GATEWAY_URL=https://apis-prelive.quran.foundation
